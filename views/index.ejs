<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo Interactivo - Tienda Local</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .product { border: 1px solid #ddd; padding: 10px; margin: 10px; display: inline-block; width: 200px; }
        .product img { max-width: 100%; height: auto; }
        .filter { margin-bottom: 20px; }
    </style>
</head>
<body>
    <h1>Catálogo de Productos</h1>
    <div class="filter">
        <label for="category">Filtrar por categoría:</label>
        <select id="category" onchange="filterProducts()">
            <option value="all" <%= selectedCategory === 'all' ? 'selected' : '' %>>Todos</option>
            <option value="electronica" <%= selectedCategory === 'electronica' ? 'selected' : '' %>>Electrónica</option>
            <option value="ropa" <%= selectedCategory === 'ropa' ? 'selected' : '' %>>Ropa</option>
            <option value="hogar" <%= selectedCategory === 'hogar' ? 'selected' : '' %>>Hogar</option>
        </select>
    </div>
    <div id="products">
        <% products.forEach(product => { %>
            <div class="product" data-category="<%= product.category %>">
                <img src="<%= product.image %>" alt="<%= product.name %>">
                <h3><a href="/product/<%= product.id %>"><%= product.name %></a></h3>
                <p>Precio: $<%= product.price %></p>
                <button onclick="addToCart(<%= product.id %>)">Añadir al carrito</button>
            </div>
        <% }); %>
    </div>

    <script src="/script.js"></script>
</body>
</html>